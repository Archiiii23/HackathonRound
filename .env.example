# DevCollab frontend env

# URL of the DevCollab backend Worker.
# Local dev: http://localhost:8787
# Production: https://devcollab-backend.<your-account>.workers.dev (or your custom domain)
VITE_API_URL=http://localhost:8787

# Server AI keys (set in .env.local for local dev; Vercel project env for production)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# MongoDB (required for npm run seed:db and local API)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/devcollab?retryWrites=true&w=majority

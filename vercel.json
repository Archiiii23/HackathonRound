{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:spa",
  "outputDirectory": "dist/client",
  "framework": null,
  "installCommand": "npm install --legacy-peer-deps",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!api/|assets/|favicon|_shell\\.html).*)", "destination": "/index.html" }
  ]
}
